"""
File: lesson1_oop_basics.py
Description: This file explains Objects, Classes, Constructors, and Destructors.
Language: Python 3
"""

# ---------------------------------------------------------
# 1. DEFINING A CLASS
# ---------------------------------------------------------
# A class is defined using the 'class' keyword.
# Think of this as the Blueprint.

class Student:
    
        # -----------------------------------------------------
            # 2. CONSTRUCTOR (__init__)
                # -----------------------------------------------------
                    # This method runs automatically when you create a new Object.
                        # It initializes the attributes (name and age).
                            def __init__(self, name, age):
                                    print(f"[Constructor] Creating a new student: {name}")
                                            self.name = name  # 'self.name' creates an attribute for this object
                                                    self.age = age
                                                            self.is_active = True

                                                                # -----------------------------------------------------
                                                                    # 3. OBJECT METHODS
                                                                        # -----------------------------------------------------
                                                                            # Functions inside a class are called methods.
                                                                                # They define what the Object can do.
                                                                                    def introduce(self):
                                                                                            if self.is_active:
                                                                                                        print(f"Hello, I am {self.name} and I am {self.age} years old.")
                                                                                                                else:
                                                                                                                            print(f"{self.name} is no longer an active student.")

                                                                                                                                def graduate(self):
                                                                                                                                        print(f"{self.name} has graduated!")
                                                                                                                                                self.is_active = False

                                                                                                                                                    # -----------------------------------------------------
                                                                                                                                                        # 4. DESTRUCTOR (__del__)
                                                                                                                                                            # -----------------------------------------------------
                                                                                                                                                                # This method runs when the object is being destroyed.
                                                                                                                                                                    # In Python, this happens when the Garbage Collector cleans up
                                                                                                                                                                        # or when the program ends.
                                                                                                                                                                            def __del__(self):
                                                                                                                                                                                    print(f"[Destructor] Object for {self.name} is being destroyed/cleaned up.")

                                                                                                                                                                                    # ---------------------------------------------------------
                                                                                                                                                                                    # MAIN PROGRAM EXECUTION
                                                                                                                                                                                    # ---------------------------------------------------------

                                                                                                                                                                                    if __name__ == "__main__":
                                                                                                                                                                                        print("--- Starting Lesson 1 Demo ---\n")

                                                                                                                                                                                            # CREATING OBJECTS (Instantiation)
                                                                                                                                                                                                # When we call Student(...), the __init__ constructor runs automatically.
                                                                                                                                                                                                    
                                                                                                                                                                                                        student1 = Student("Alice", 20)
                                                                                                                                                                                                            student2 = Student("Brian", 22)

                                                                                                                                                                                                                print("\n--- Using Object Methods ---")
                                                                                                                                                                                                                    # Accessing methods and attributes
                                                                                                                                                                                                                        student1.introduce()
                                                                                                                                                                                                                            student2.introduce()

                                                                                                                                                                                                                                print("\n--- Modifying Object State ---")
                                                                                                                                                                                                                                    student1.graduate()
                                                                                                                                                                                                                                        student1.introduce() # Now Alice is not active

                                                                                                                                                                                                                                            print("\n--- Deleting Objects ---")
                                                                                                                                                                                                                                                # We can manually delete an object using 'del'
                                                                                                                                                                                                                                                    # This triggers the Destructor (__del__)
                                                                                                                                                                                                                                                        del student1
                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                print("\n--- End of Program ---")
                                                                                                                                                                                                                                                                    # Note: student2 will be destroyed automatically when the program finishes,
                                                                                                                                                                                                                                                                        # triggering its destructor as well."""
                                                                                                                                                                                                                                                                        File: lesson1_oop_basics.py
                                                                                                                                                                                                                                                                        Description: This file explains Objects, Classes, Constructors, and Destructors.
                                                                                                                                                                                                                                                                        Language: Python 3
                                                                                                                                                                                                                                                                        """

                                                                                                                                                                                                                                                                        # ---------------------------------------------------------
                                                                                                                                                                                                                                                                        # 1. DEFINING A CLASS
                                                                                                                                                                                                                                                                        # ---------------------------------------------------------
                                                                                                                                                                                                                                                                        # A class is defined using the 'class' keyword.
                                                                                                                                                                                                                                                                        # Think of this as the Blueprint.

                                                                                                                                                                                                                                                                        class Student:
                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                # -----------------------------------------------------
                                                                                                                                                                                                                                                                                    # 2. CONSTRUCTOR (__init__)
                                                                                                                                                                                                                                                                                        # -----------------------------------------------------
                                                                                                                                                                                                                                                                                            # This method runs automatically when you create a new Object.
                                                                                                                                                                                                                                                                                                # It initializes the attributes (name and age).
                                                                                                                                                                                                                                                                                                    def __init__(self, name, age):
                                                                                                                                                                                                                                                                                                            print(f"[Constructor] Creating a new student: {name}")
                                                                                                                                                                                                                                                                                                                    self.name = name  # 'self.name' creates an attribute for this object
                                                                                                                                                                                                                                                                                                                            self.age = age
                                                                                                                                                                                                                                                                                                                                    self.is_active = True

                                                                                                                                                                                                                                                                                                                                        # -----------------------------------------------------
                                                                                                                                                                                                                                                                                                                                            # 3. OBJECT METHODS
                                                                                                                                                                                                                                                                                                                                                # -----------------------------------------------------
                                                                                                                                                                                                                                                                                                                                                    # Functions inside a class are called methods.
                                                                                                                                                                                                                                                                                                                                                        # They define what the Object can do.
                                                                                                                                                                                                                                                                                                                                                            def introduce(self):
                                                                                                                                                                                                                                                                                                                                                                    if self.is_active:
                                                                                                                                                                                                                                                                                                                                                                                print(f"Hello, I am {self.name} and I am {self.age} years old.")
                                                                                                                                                                                                                                                                                                                                                                                        else:
                                                                                                                                                                                                                                                                                                                                                                                                    print(f"{self.name} is no longer an active student.")

                                                                                                                                                                                                                                                                                                                                                                                                        def graduate(self):
                                                                                                                                                                                                                                                                                                                                                                                                                print(f"{self.name} has graduated!")
                                                                                                                                                                                                                                                                                                                                                                                                                        self.is_active = False

                                                                                                                                                                                                                                                                                                                                                                                                                            # -----------------------------------------------------
                                                                                                                                                                                                                                                                                                                                                                                                                                # 4. DESTRUCTOR (__del__)
                                                                                                                                                                                                                                                                                                                                                                                                                                    # -----------------------------------------------------
                                                                                                                                                                                                                                                                                                                                                                                                                                        # This method runs when the object is being destroyed.
                                                                                                                                                                                                                                                                                                                                                                                                                                            # In Python, this happens when the Garbage Collector cleans up
                                                                                                                                                                                                                                                                                                                                                                                                                                                # or when the program ends.
                                                                                                                                                                                                                                                                                                                                                                                                                                                    def __del__(self):
                                                                                                                                                                                                                                                                                                                                                                                                                                                            print(f"[Destructor] Object for {self.name} is being destroyed/cleaned up.")

                                                                                                                                                                                                                                                                                                                                                                                                                                                            # ---------------------------------------------------------
                                                                                                                                                                                                                                                                                                                                                                                                                                                            # MAIN PROGRAM EXECUTION
                                                                                                                                                                                                                                                                                                                                                                                                                                                            # ---------------------------------------------------------

                                                                                                                                                                                                                                                                                                                                                                                                                                                            if __name__ == "__main__":
                                                                                                                                                                                                                                                                                                                                                                                                                                                                print("--- Starting Lesson 1 Demo ---\n")

                                                                                                                                                                                                                                                                                                                                                                                                                                                                    # CREATING OBJECTS (Instantiation)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        # When we call Student(...), the __init__ constructor runs automatically.
                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                student1 = Student("Alice", 20)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    student2 = Student("Brian", 22)

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        print("\n--- Using Object Methods ---")
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            # Accessing methods and attributes
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                student1.introduce()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    student2.introduce()

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        print("\n--- Modifying Object State ---")
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            student1.graduate()
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                student1.introduce() # Now Alice is not active

                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    print("\n--- Deleting Objects ---")
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        # We can manually delete an object using 'del'
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            # This triggers the Destructor (__del__)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                del student1
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        print("\n--- End of Program ---")
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            # Note: student2 will be destroyed automatically when the program finishes,
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                # triggering its destructor as well.